# ===========================================
# EMTOOLS Backend Environment Variables
# Version: 1.0.0-alpha
# ===========================================
# Copy this file to .env and configure for your environment
# NEVER commit the actual .env file to version control!

# ===========================================
# ENVIRONMENT
# ===========================================
# development | staging | production
ENVIRONMENT=development
DEBUG=true

# ===========================================
# DATABASE
# ===========================================
# MongoDB connection string
# For Docker production: mongodb://admin:password@mongodb:27017
# For MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=emtools

# MongoDB credentials (for docker-compose.prod.yml)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change-this-strong-password

# ===========================================
# SECURITY - CRITICAL FOR PRODUCTION!
# ===========================================
# Generate a secure secret key:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-development-secret-key-change-in-production

# JWT Token Expiration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# ADMIN ACCOUNT - CHANGE IN PRODUCTION!
# ===========================================
ADMIN_EMAIL=admin@emtools.com
ADMIN_PASSWORD=change-this-strong-password-min-12-chars
FIRST_SUPERUSER_EMAIL=admin@emtools.com
FIRST_SUPERUSER_PASSWORD=admin123

# ===========================================
# CORS - Configure for your frontend domain
# ===========================================
# For production: ["https://emtools.com","https://www.emtools.com"]
# For development: ["http://localhost:5173","http://localhost:3000"]
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ORIGINS=["http://localhost:5173"]

# ===========================================
# DOCKER CONFIGURATION
# ===========================================
# Docker Hub registry (your-username or organization)
DOCKER_REGISTRY=emtools
VERSION=1.0.0-alpha

# ===========================================
# SECURITY LIMITS
# ===========================================
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ===========================================
# PASTE LIMITS
# ===========================================
MAX_PASTE_SIZE_KB=500
MAX_PASTE_EXPIRY_HOURS=24
