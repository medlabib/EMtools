# ===========================================
# EMTOOLS Backend Environment Variables
# ===========================================
# Copy this file to .env and configure for your environment
# NEVER commit the actual .env file to version control!

# ===========================================
# ENVIRONMENT
# ===========================================
ENVIRONMENT=development
DEBUG=true

# ===========================================
# DATABASE
# ===========================================
# MongoDB connection string
# For production, use MongoDB Atlas or secured MongoDB instance
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=emtools

# ===========================================
# SECURITY - CRITICAL FOR PRODUCTION!
# ===========================================
# Generate a secure secret key:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-development-secret-key-change-in-production

# JWT Token Expiration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# ADMIN ACCOUNT - CHANGE IN PRODUCTION!
# ===========================================
FIRST_SUPERUSER_EMAIL=admin@emtools.com
FIRST_SUPERUSER_PASSWORD=admin123

# ===========================================
# CORS - Configure for your frontend domain
# ===========================================
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# SECURITY LIMITS
# ===========================================
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ===========================================
# PASTE LIMITS
# ===========================================
MAX_PASTE_SIZE_KB=500
MAX_PASTE_EXPIRY_HOURS=24
